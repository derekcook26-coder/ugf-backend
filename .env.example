GYMMASTER_API_KEY=your_gymmaster_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Goals Coach Phase 1A private-alpha foundation. Disabled by default.
GOALS_COACH_ALPHA_ENABLED=false
GOALS_COACH_ALPHA_ENVIRONMENT=development
GOALS_COACH_ALPHA_CONSENT_VERSION=GC-ALPHA-CONSENT-1.0
GOALS_COACH_ALPHA_DEVELOPMENT_ORIGINS=http://localhost:3100
GOALS_COACH_ALPHA_ORIGIN=
GOALS_COACH_MEMBER_CLERK_SECRET_KEY=
GOALS_COACH_MEMBER_CLERK_PUBLISHABLE_KEY=
GOALS_COACH_MEMBER_CLERK_ISSUER=
GOALS_COACH_MEMBER_CLERK_AUDIENCE=goals-coach-alpha-api

# Goals Coach Phase 1B coaching intelligence. Disabled by default. The current
# startup has no live provider adapter and therefore remains fail closed even
# when these non-secret identifiers are prepared.
GOALS_COACH_AI_ENABLED=false
GOALS_COACH_AI_PROVIDER=
GOALS_COACH_OPENAI_MODEL=
GOALS_COACH_PROMPT_VERSION=
GOALS_COACH_STRUCTURED_OUTPUT_VERSION=
GOALS_COACH_SAFETY_RULE_VERSION=phase-1b-placeholder
GOALS_COACH_PROVIDER_TIMEOUT_MS=15000
